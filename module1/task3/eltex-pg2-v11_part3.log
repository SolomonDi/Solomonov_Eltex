ls -l
mkdir -p D1/D2/D3
ls -R D1
touch D1/D2/file.txt
echo "Hello there!" > D1/D2/file.txt
ln D1/D2/file.txt D1/D2/D3/file_hard.lnk
ls -li D1/D2/file.txt D1/D2/D3/file_hard.lnk
ln -s ../file.txt D1/D2/D3/file_sym.lnk
ls -li D1/D2/file.txt D1/D2/D3/file_sym.lnk
mv D1/D2/file.txt D1/
ls -RF D1
cat D1/D2/D3/file_hard.lnk
cat D1/D2/D3/file_sym.lnk
rm -rf D1/D2
ls -RF D1
find / -type f -size +20M 2>/dev/null > "${USER}_part3_gt50M.log"
cat "${USER}_part3_gt50M.log" | xargs du -sh 2>/dev/null
find ~ -type f -mtime -1
which find
file /usr/bin/find
file /boot/initrd.img*
